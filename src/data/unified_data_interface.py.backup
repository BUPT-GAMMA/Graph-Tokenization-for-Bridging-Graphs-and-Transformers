"""
Unified Data Interface
======================

设计原则：
- 单一数据文件 + 索引划分；
- 对上层（序列化/BPE/训练）提供统一读取接口；
- 序列化与 BPE 的缓存管理是接口内部细节，数据构建需显式调用；
- 简化接口：两个核心方法 get_sequences() 和 get_sequences_by_splits()。
"""

from __future__ import annotations

import json
import pickle
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Dict, List, Tuple, Optional

from config import ProjectConfig
from src.data.unified_data_factory import get_dataloader
from src.data.base_loader import BaseDataLoader
from src.algorithms.serializer.serializer_factory import SerializerFactory
from src.algorithms.compression.bpe_engine import BPEEngine
from src.data.transforms.bpe_transform import BPETokenTransform
# from src.models.bert.vocab_manager import build_vocab_from_sequences  # 延迟导入避免循环依赖


@dataclass
class UnifiedDataInterface:
    config: ProjectConfig
    dataset: str
    # 运行期可选的预加载缓存（同一进程内复用，避免重复IO/构建）
    _preloaded_graphs: List[Dict[str, Any]] | None = None
    _preloaded_splits: Dict[str, List[int]] | None = None
    _loader: BaseDataLoader | None = None

    def _resolve_processed_dir(self) -> Path:
        return Path(self.config.processed_data_dir) / self.dataset

    # ----------------------- 版本解析与发现 -----------------------
    def _resolve_version_dir(self, data_version: Optional[str] = "latest") -> Path:
        """解析版本目录。

        规则：
        - data_version == None 或 "latest":
          在 `processed/<dataset>/` 下选择最近修改的候选目录；
          候选集包含根目录本身（用于兼容历史布局）以及子目录（排除 'serialized_data' 与 'bpe_compressed' 这类阶段目录）。
        - 其他字符串：直接返回对应的版本子目录。
        """
        base = self._resolve_processed_dir()
        if data_version is not None and data_version != "latest":
            return base / data_version

        # latest 解析：若存在任何版本子目录，则仅在子目录中选择最新；否则回退为根目录
        version_dirs: List[Path] = []
        if base.exists():
            for p in base.iterdir():
                if p.is_dir() and p.name not in {"serialized_data", "bpe_compressed"}:
                    version_dirs.append(p)

        if version_dirs:
            def _mtime(path: Path) -> float:
                try:
                    return path.stat().st_mtime
                except Exception:
                    return 0.0
            version_dirs.sort(key=_mtime, reverse=True)
            return version_dirs[0]

        # 无版本子目录时，使用根路径（调用方在 build_if_missing=True 时会创建）
        return base

    def list_available_versions(self) -> List[str]:
        """列出可用的数据版本名称。

        返回：按名称升序排列；特殊项 'root' 表示根目录（历史布局）。
        """
        base = self._resolve_processed_dir()
        # 总是包含 root（历史布局）
        versions: List[str] = ["root"]
        if base.exists():
            for p in base.iterdir():
                if p.is_dir() and p.name not in {"serialized_data", "bpe_compressed"}:
                    versions.append(p.name)
        return sorted(set(versions))

    def resolve_version(self, data_version: Optional[str] = "latest") -> str:
        """解析版本名称（可用于记录）。

        - 返回 'root' 表示使用根目录（历史布局）
        - 返回子目录名表示使用该版本目录
        """
        base = self._resolve_processed_dir()
        target = self._resolve_version_dir(data_version)
        return "root" if target == base else target.name

    def _load_split_indices(self) -> Dict[str, List[int]]:
        """加载原有格式的划分索引文件"""
        # 使用项目配置的 data_dir，确保加载真实项目数据而非当前工作目录
        data_dir = Path(self.config.data_dir) / self.dataset
        
        train_path = data_dir / "train_index.json"
        val_path = data_dir / "val_index.json"
        test_path = data_dir / "test_index.json"
        
        splits = {}
        
        # 加载训练集索引
        if train_path.exists():
            with open(train_path, 'r') as f:
                splits['train'] = json.load(f)
        else:
            raise FileNotFoundError(f"训练集索引文件不存在: {train_path}")
        
        # 加载验证集索引  
        if val_path.exists():
            with open(val_path, 'r') as f:
                splits['val'] = json.load(f)
        else:
            raise FileNotFoundError(f"验证集索引文件不存在: {val_path}")
        
        # 加载测试集索引
        if test_path.exists():
            with open(test_path, 'r') as f:
                splits['test'] = json.load(f)
        else:
            raise FileNotFoundError(f"测试集索引文件不存在: {test_path}")
        
        return splits

    # ----------------------- 预加载图/索引（避免重复构建） -----------------------
    def preload_graphs(self) -> None:
        """主动加载并缓存全量图与划分索引，供后续序列化/BPE 构建复用。"""
        loader = self.get_dataset_loader()
        graphs, _ = loader.get_all_data_with_indices()
        self._loader=loader
        self._preloaded_graphs = graphs
        self._preloaded_splits = self._load_split_indices()

    def _get_serialization_cache_key(self) -> str:
        """生成基于配置的序列化缓存键"""
        tr = self.config.dataset.transforms
        use_multi = getattr(tr, 'use_multiple_serialization', False)
        num_realizations = getattr(tr, 'num_realizations', 1)
        
        if use_multi and num_realizations > 1:
            return f"multi_{num_realizations}"
        else:
            return "single"
    
    def _load_serialization_result(self, method: str) -> Dict[str, Any]:
        """内部方法：加载序列化结果"""
        base = self._resolve_version_dir("latest")
        cache_key = self._get_serialization_cache_key()
        result_path = base / "serialized_data" / method / cache_key / "serialized_data.pickle"
        
        if not result_path.exists():
            raise FileNotFoundError(f"序列化结果不存在: {result_path}")
        
        with open(result_path, 'rb') as f:
            data = pickle.load(f)
            
        if data.get('serialization_method') != method:
            raise ValueError(f"请求的序列化方法 '{method}' 与保存的方法 '{data.get('serialization_method')}' 不匹配")
        
        return data

    # ----------------------- 构建与持久化（显式触发） -----------------------
    def _extract_properties_from_graphs(self, graphs: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
        """从原始图数据中提取属性信息（数值/短字符串），用于写入缓存。

        说明：保持与 data_prepare 中的提取口径一致，避免依赖底层 data.pkl。
        """
        try:
            import numpy as np  # 局部导入，避免顶层依赖
        except Exception:
            np = None  # 测试环境可不严格依赖

        graph_structure_keys = {
            'dgl_graph', 'graph', 'edge_index', 'edge_attr', 'node_features', 'edge_features',
            'num_nodes', 'num_edges', 'adjacency', 'adjacency_matrix', 'node_attr',
            'smiles', 'mol', 'molecule', 'rdkit_mol',
            'id', 'index', 'idx', 'dataset_name', 'data_type',
            'node_ids', 'edge_ids', 'global_node_ids',
            'smiles_1', 'smiles_2', 'smiles_3', 'smiles_4'
        }

        properties: List[Dict[str, Any]] = []
        for item in graphs:
            prop: Dict[str, Any] = {}
            if isinstance(item, dict):
                if 'properties' in item and isinstance(item['properties'], dict):
                    prop.update(item['properties'])
                for k, v in item.items():
                    if k in graph_structure_keys:
                        continue
                    if isinstance(v, (int, float)):
                        prop[k] = float(v)
                    elif isinstance(v, str) and len(v) < 50:
                        prop[k] = v
                    elif np is not None and isinstance(v, (np.integer, np.floating)):
                        prop[k] = float(v)
            properties.append(prop)
        return properties

    def _build_and_persist_serialization(self, method: str) -> Path:
        """在缓存缺失时，按当前配置确定性地构建序列化结果并持久化，返回结果路径。"""
        # 获取数据
        if self._preloaded_graphs is not None:
            graphs = self._preloaded_graphs
            loader = self.get_dataset_loader()
        else:
            loader = self.get_dataset_loader()
            graphs, _ = loader.get_all_data_with_indices()

        # 初始化序列化器
        serializer = SerializerFactory.create_serializer(method)
        serializer.initialize_with_dataset(loader, graphs)

        # multiple 逻辑：按配置决定是否为每图产生多变体
        tr = self.config.dataset.transforms
        use_multi = bool(tr.use_multiple_serialization)
        num_realizations = int(tr.num_realizations)

        sequences: List[List[int]] = []
        graph_ids: List[int] = []
        variant_ids: List[int] = []
        flattened_properties: List[Dict[str, Any]] = []

        # 提取属性（用于与序列对齐）
        properties = self._extract_properties_from_graphs(graphs)

        if use_multi and num_realizations > 1:
            # 批量多次序列化
            batch_results = serializer.batch_multiple_serialize(
                graphs, num_samples=num_realizations, desc=f"serialize-multi-{method}", parallel=False
            )
            # 逐图展开变体
            for gid, res in enumerate(batch_results):
                if res is None:
                    raise ValueError(f"序列化失败: 图 {gid} 返回空结果")
                if not hasattr(res, 'token_sequences'):
                    raise ValueError(f"序列化结果格式错误: 图 {gid} 缺少 token_sequences 属性")
                if not res.token_sequences:
                    raise ValueError(f"序列化结果为空: 图 {gid} 的 token_sequences 为空")
                    
                for vid, seq in enumerate(res.token_sequences):
                    sequences.append(seq)
                    graph_ids.append(gid)
                    variant_ids.append(vid)
                    if gid >= len(properties):
                        raise IndexError(f"属性索引越界: 图 {gid} 超出属性列表长度 {len(properties)}")
                    flattened_properties.append(properties[gid])
        else:
            # 单次序列化
            batch_results = serializer.batch_serialize(graphs, desc=f"serialize-{method}")
            for gid, res in enumerate(batch_results):
                if res is None:
                    raise ValueError(f"序列化失败: 图 {gid} 返回空结果")
                if not hasattr(res, 'token_sequences'):
                    raise ValueError(f"序列化结果格式错误: 图 {gid} 缺少 token_sequences 属性")
                if not res.token_sequences:
                    raise ValueError(f"序列化结果为空: 图 {gid} 的 token_sequences 为空")
                    
                sequences.append(res.token_sequences[0])
                graph_ids.append(gid)
                variant_ids.append(0)
                if gid >= len(properties):
                    raise IndexError(f"属性索引越界: 图 {gid} 超出属性列表长度 {len(properties)}")
                flattened_properties.append(properties[gid])

        # 写入
        cache_key = self._get_serialization_cache_key()
        out_dir = self._resolve_version_dir("latest") / "serialized_data" / method / cache_key
        out_dir.mkdir(parents=True, exist_ok=True)
        out_path = out_dir / "serialized_data.pickle"
        with out_path.open('wb') as f:
            pickle.dump({
                'sequences': sequences,
                'properties': flattened_properties,
                'serialization_method': method,
                'graph_ids': graph_ids,
                'variant_ids': variant_ids,
            }, f)
        return out_path

    def _build_and_persist_bpe(self, method: str, data_version: Optional[str] = "latest") -> Path:
        """在缓存缺失时，按当前配置构建BPE压缩并持久化，返回结果路径。"""
        # 依赖序列化结果
        try:
            ser = self._load_serialization_result(method, data_version)
        except FileNotFoundError:
            # 显式允许在BPE构建时一并构建序列化结果
            self._build_and_persist_serialization(method, data_version)
            ser = self._load_serialization_result(method, data_version)

        sequences: List[List[int]] = ser.get('sequences', [])
        properties: List[Dict[str, Any]] = ser.get('properties', [])

        # 使用统一 BPEEngine
        eng_cfg = self.config.serialization.bpe.engine
        engine = BPEEngine(
            train_backend=str(eng_cfg.train_backend),
            encode_backend=str(eng_cfg.encode_backend),
            encode_rank_mode=str(eng_cfg.encode_rank_mode),
            encode_rank_k=eng_cfg.encode_rank_k,
            encode_rank_min=eng_cfg.encode_rank_min,
            encode_rank_max=eng_cfg.encode_rank_max,
            encode_rank_dist=eng_cfg.encode_rank_dist,
        )
        engine.train(sequences, num_merges=int(self.config.serialization.bpe.num_merges),
                     min_frequency=int(self.config.serialization.bpe.min_frequency))
        engine.build_encoder()
        compressed_sequences = engine.batch_encode(sequences)

        out_dir = self._resolve_version_dir(data_version) / "bpe_compressed" / method
        out_dir.mkdir(parents=True, exist_ok=True)
        out_path = out_dir / "compressed_data.pickle"
        with out_path.open('wb') as f:
            pickle.dump({
                'compressed_sequences': compressed_sequences,
                'sequences': sequences,
                'properties': properties,
                # 仅保存 codebook 与编码策略配置，避免跨进程传输大对象
                'bpe_model': {
                    'merge_rules': engine.merge_rules,
                    'vocab_size': engine.vocab_size,
                    'encode_backend': str(eng_cfg.encode_backend),
                    'encode_rank_mode': str(eng_cfg.encode_rank_mode),
                    'encode_rank_k': eng_cfg.encode_rank_k,
                    'encode_rank_min': eng_cfg.encode_rank_min,
                    'encode_rank_max': eng_cfg.encode_rank_max,
                    'encode_rank_dist': eng_cfg.encode_rank_dist,
                },
                'serialization_method': method,
            }, f)
        return out_path

    def _load_bpe_result(self, method: str, data_version: Optional[str] = "latest") -> Dict[str, Any]:
        """内部方法：加载 BPE 压缩结果"""
        base = self._resolve_version_dir(data_version)
        result_path = base / "bpe_compressed" / method / "compressed_data.pickle"
        
        if not result_path.exists():
            raise FileNotFoundError(f"BPE 结果不存在: {result_path}")
        
        with open(result_path, 'rb') as f:
            return pickle.load(f)

    # ----------------------- BPE codebook 与 Transform -----------------------
    def get_bpe_codebook(self, method: str, data_version: Optional[str] = "latest") -> Dict[str, Any]:
        """读取 BPE codebook（优先 model_dir 下的轻量文件；否则回退读取 bpe_compressed 中的元信息）。"""
        # model_dir 下的标准路径
        try:
            model_path = self.config.get_bpe_model_path(self.dataset, method)
            if model_path.exists():
                with model_path.open('rb') as f:
                    data = pickle.load(f)
                if isinstance(data, dict) and 'merge_rules' in data and 'vocab_size' in data:
                    return {'merge_rules': data['merge_rules'], 'vocab_size': int(data['vocab_size'])}
        except Exception:
            pass

        # 从 bpe_compressed 的记录中获取（要求结构完备）
        meta = self._load_bpe_result(method, data_version).get('bpe_model')
        if not isinstance(meta, dict) or 'merge_rules' not in meta or 'vocab_size' not in meta:
            raise ValueError("缺少 BPE codebook（merge_rules/vocab_size）")
        return {'merge_rules': meta['merge_rules'], 'vocab_size': int(meta['vocab_size'])}

    def create_bpe_transform_from_config(self, method: str) -> BPETokenTransform:
        codebook = self.get_bpe_codebook(method)
        tr = self.config.dataset.transforms
        
        # 获取BPE配置，优先使用transform级别的配置，回退到engine级别
        bpe_mode = getattr(tr, 'bpe_mode', None)
        if bpe_mode is None:
            bpe_mode = self.config.serialization.bpe.engine.encode_rank_mode
        
        return BPETokenTransform(
            merge_rules=codebook['merge_rules'],
            vocab_size=int(codebook['vocab_size']),
            encode_backend=str(self.config.serialization.bpe.engine.encode_backend),
            encode_rank_mode=str(bpe_mode),
            encode_rank_k=getattr(tr, 'bpe_topk', None),
            encode_rank_min=getattr(tr, 'bpe_rank_min', None),
            encode_rank_max=getattr(tr, 'bpe_rank_max', None),
            encode_rank_dist=getattr(tr, 'bpe_rank_dist', None),
            # 评估模式配置
            eval_mode=getattr(tr, 'bpe_eval_mode', None),
            eval_topk=getattr(tr, 'bpe_eval_topk', None),
        )

    # ----------------------- 核心序列读取接口 -----------------------
    def get_sequences(self, method: str) -> Tuple[List[Tuple[List[int], int]], List[Dict[str, Any]]]:
        """
        获取所有序列数据和标签
        
        Args:
            method: 序列化方法名
            
        Returns:
            Tuple[List[Tuple[List[int], int]], List[Dict[str, Any]]]:
                - 第一个元素: [(序列, 图ID), ...] 列表
                - 第二个元素: [标签属性字典, ...] 列表
        """
        serialized = self._load_serialization_result(method)
        
        sequences = serialized.get('sequences', [])
        if not sequences:
            raise ValueError("序列化序列为空")
        
        # 获取图ID (支持新格式的graph_ids或回退到索引)
        if 'graph_ids' in serialized:
            graph_ids = serialized['graph_ids']
        else:
            # 回退：假设序列按图顺序排列
            graph_ids = list(range(len(sequences)))
            
        properties = serialized.get('properties', [])
        if not properties:
            # 如果没有属性，创建空字典列表
            properties = [{} for _ in sequences]
            
        # 组装返回格式
        sequences_with_ids = [(seq, gid) for seq, gid in zip(sequences, graph_ids)]
        
        return sequences_with_ids, properties

    def get_sequences_by_splits(self, method: str) -> Tuple[
        List[Tuple[List[int], int]], List[Dict[str, Any]],  # train
        List[Tuple[List[int], int]], List[Dict[str, Any]],  # val  
        List[Tuple[List[int], int]], List[Dict[str, Any]]   # test
    ]:
        """
        按训练/验证/测试划分获取序列数据
        
        Args:
            method: 序列化方法名
            
        Returns:
            Tuple of 6 elements:
                (train_sequences, train_labels, val_sequences, val_labels, test_sequences, test_labels)
        """
        # 获取全部数据
        all_sequences, all_labels = self.get_sequences(method)
        
        # 获取划分索引
        split_indices = self._load_split_indices()
        
        # 构建图ID到索引的映射
        graph_id_to_indices = {}
        for idx, (seq, graph_id) in enumerate(all_sequences):
            if graph_id not in graph_id_to_indices:
                graph_id_to_indices[graph_id] = []
            graph_id_to_indices[graph_id].append(idx)
        
        def extract_split_data(split_name: str):
            if split_name not in split_indices:
                raise ValueError(f"无效的划分名称: {split_name}")
            
            split_graph_ids = set(split_indices[split_name])
            split_sequences = []
            split_labels = []
            
            for graph_id in split_graph_ids:
                if graph_id in graph_id_to_indices:
                    for idx in graph_id_to_indices[graph_id]:
                        split_sequences.append(all_sequences[idx])
                        split_labels.append(all_labels[idx])
            
            return split_sequences, split_labels
        
        train_seqs, train_labels = extract_split_data('train')
        val_seqs, val_labels = extract_split_data('val') 
        test_seqs, test_labels = extract_split_data('test')
        
        return train_seqs, train_labels, val_seqs, val_labels, test_seqs, test_labels

    def get_bpe_worker_init_and_collate(self, method: str):
        """返回 (worker_init_fn, collate) 以便 DataLoader 在线 BPE 编码。

        约定：mini-batch 的 item 为 dict，且包含原始序列键 'seq'。
        """
        from src.data.transforms.bpe_transform import make_worker_init_fn, bpe_batch_encode_in_worker
        codebook = self.get_bpe_codebook(method)
        tr = self.config.dataset.transforms
        
        # 获取BPE配置，优先使用transform级别的配置，回退到engine级别
        bpe_mode = getattr(tr, 'bpe_mode', None)
        if bpe_mode is None:
            bpe_mode = self.config.serialization.bpe.engine.encode_rank_mode
            
        kwargs = dict(
            encode_backend=str(self.config.serialization.bpe.engine.encode_backend),
            encode_rank_mode=str(bpe_mode),
            encode_rank_k=getattr(tr, 'bpe_topk', None),
            encode_rank_min=getattr(tr, 'bpe_rank_min', None),
            encode_rank_max=getattr(tr, 'bpe_rank_max', None),
            encode_rank_dist=getattr(tr, 'bpe_rank_dist', None),
        )
        worker_init = make_worker_init_fn(codebook, kwargs)

        def _collate(batch):
            seqs = [it['seq'] for it in batch]
            ids = bpe_batch_encode_in_worker(seqs)
            return ids

        return worker_init, _collate

    # ----------------------- 统一词表（构建/读取） -----------------------
    def ensure_unified_vocab(
        self,
        method: str,
        data_version: str = "latest",
        *,
        min_freq: int = 1,
        max_vocab_size: Optional[int] = None,
        build_if_missing: bool = True,
    ) -> Path:
        """确保存在统一词表（base+merge+special 的全集）。

        若缺失则从原始序列构建（可选 build_if_missing）。
        返回保存路径。
        """
        base = self._resolve_version_dir(data_version)
        vocab_path = base / "vocab" / method / "bpe" / "vocab.json"
        if vocab_path.exists():
            return vocab_path
        if not build_if_missing:
            raise FileNotFoundError(f"词表不存在: {vocab_path}")

        # 构建统一词表：基于原始序列 + BPE merge rules + 特殊tokens
        # 1. 获取原始序列（用于基础token）
        sequences, _splits = None, None
        try:
            sequences, _splits = self.get_sequences(method, data_version, build_if_missing=True)
        except Exception:
            # 序列缺失则显式构建
            self._build_and_persist_serialization(method, data_version)
            sequences, _splits = self.get_sequences(method, data_version, build_if_missing=False)

        # 2. 获取BPE codebook（用于merge tokens）
        try:
            codebook = self.get_bpe_codebook(method, data_version)
        except Exception:
            # BPE缺失则先构建
            self.prepare_bpe(method, data_version)
            codebook = self.get_bpe_codebook(method, data_version)

        # 3. 构建包含所有token的统一词表
        from src.models.bert.vocab_manager import build_vocab_from_sequences
        
        # 创建包含所有可能token的扩展序列
        # 基础tokens: 从原始序列中提取
        all_base_tokens = set()
        for seq in sequences:
            all_base_tokens.update(seq)
        
        # BPE merge tokens: 从merge_rules中提取新增的token ID
        merge_tokens = set()
        for _, _, new_token_id in codebook['merge_rules']:
            merge_tokens.add(new_token_id)
        
        # 构建扩展序列：确保词表包含所有可能的token
        extended_sequences = [list(all_base_tokens) + list(merge_tokens)]
        
        vocab = build_vocab_from_sequences(extended_sequences, self.config, min_freq=1, max_vocab_size=max_vocab_size)
        out_path = self.register_vocab(vocab, method=method, bpe=True, data_version=data_version)
        return out_path

    # ----------------------- 状态查询/报告 与 注册接口 -----------------------
    def has_serialized(self, method: str) -> bool:
        base = self._resolve_version_dir("latest")
        cache_key = self._get_serialization_cache_key()
        result_path = base / "serialized_data" / method / cache_key / "serialized_data.pickle"
        return result_path.exists()

    def has_bpe(self, method: str, data_version: str = "latest") -> bool:
        base = self._resolve_version_dir(data_version)
        result_path = base / "bpe_compressed" / method / "compressed_data.pickle"
        return result_path.exists()

    def has_vocab(self, method: str, bpe: bool, data_version: str = "latest") -> bool:
        base = self._resolve_version_dir(data_version)
        sub = "bpe" if bpe else "raw"
        vocab_dir = base / "vocab" / method / sub
        return (vocab_dir / "vocab.json").exists()

    def get_vocab(self, method: str, bpe: bool, data_version: str = "latest"):
        """读取与数据集/版本绑定的词表。缺失直接报错。"""
        base = self._resolve_version_dir(data_version)
        # 统一词表：读取 bpe 子目录（全集）
        sub = "bpe"
        vocab_path = base / "vocab" / method / sub / "vocab.json"
        if not vocab_path.exists():
            raise FileNotFoundError(f"词表不存在: {vocab_path}")
        from src.models.bert.vocab_manager import VocabManager  # 局部导入避免循环依赖
        return VocabManager.load_vocab(str(vocab_path), self.config)

    def register_vocab(self, vocab_manager, method: str, bpe: bool, data_version: str = "latest") -> Path:
        """注册（落盘）词表到数据集的 processed 目录。

        返回保存路径。
        """
        base = self._resolve_version_dir(data_version)
        # 统一词表：默认注册到 bpe 子目录，表示“base+merge+special”全集
        sub = "bpe"
        out_dir = base / "vocab" / method / sub
        out_dir.mkdir(parents=True, exist_ok=True)
        out_path = out_dir / "vocab.json"
        vocab_manager.save_vocab(str(out_path))
        return out_path

    def register_serialized_sequences(
        self,
        method: str,
        sequences: List[List[int]],
        properties: List[Dict[str, Any]] | None,
        split_indices: Dict[str, List[int]] | None,
        data_version: str = "latest",
    ) -> Path:
        """注册（落盘）外部提供的序列化结果。

        说明：split_indices 参数目前不单独落盘（索引文件位于 data_dir/<dataset>/ 下）。
        """
        cache_key = self._get_serialization_cache_key()
        out_dir = self._resolve_version_dir(data_version) / "serialized_data" / method / cache_key
        out_dir.mkdir(parents=True, exist_ok=True)
        out_path = out_dir / "serialized_data.pickle"
        with out_path.open('wb') as f:
            pickle.dump({
                'sequences': sequences,
                'properties': properties or [],
                'serialization_method': method,
            }, f)
        return out_path

    def register_bpe_compressed(
        self,
        method: str,
        compressed_sequences: List[List[int]],
        bpe_model: Any,
        properties: List[Dict[str, Any]] | None,
        split_indices: Dict[str, List[int]] | None,
        data_version: str = "latest",
    ) -> Path:
        """注册（落盘）外部提供的 BPE 压缩结果与 BPE 模型。"""
        out_dir = self._resolve_version_dir(data_version) / "bpe_compressed" / method
        out_dir.mkdir(parents=True, exist_ok=True)
        out_path = out_dir / "compressed_data.pickle"
        with out_path.open('wb') as f:
            pickle.dump({
                'compressed_sequences': compressed_sequences,
                'sequences': None,
                'properties': properties or [],
                'bpe_model': bpe_model,
                'serialization_method': method,
            }, f)
        return out_path

    def prepare_serialization(self, method: str) -> Path:
        """显式构建并持久化序列化结果（供顶层准备器使用）。"""
        return self._build_and_persist_serialization(method)

    def prepare_bpe(self, method: str, data_version: str = "latest") -> Path:
        """显式构建并持久化 BPE 压缩结果（供顶层准备器使用）。"""
        return self._build_and_persist_bpe(method, data_version)

    def get_graphs(self, data_version: str = "latest") -> List[Dict[str, Any]]:
        # 读取图与属性（通过 loader），不在此方法内做切分
        if self._preloaded_graphs is not None:
            return self._preloaded_graphs
        loader = get_dataloader(self.dataset, self.config)
        all_data, _ = loader.get_all_data_with_indices()
        return all_data



    def get_compressed_sequences(self, method: str) -> Tuple[List[List[int]], Dict[str, List[int]]]:
        # 加载划分索引
        split_indices = self._load_split_indices()

        # 尝试读取 BPE 压缩结果
        try:
            bpe_res = self._load_bpe_result(method, data_version)
        except FileNotFoundError:
            if not build_if_missing:
                raise
            # 显式构建并重载
            self._build_and_persist_bpe(method, data_version)
            bpe_res = self._load_bpe_result(method, data_version)

        compressed = bpe_res.get("compressed_sequences", [])
        if not compressed:
            raise ValueError("BPE 压缩序列为空")

        return compressed, split_indices



    # 2) 纯内存端到端处理：已弃用（遵循“无隐式回退/不在 UDI 内构建”的规范）

    def get_all_sequences(
        self,
        method: str,
        *,
        use_bpe: bool = True,
        data_version: str = "latest",
        build_if_missing: bool = False,
    ) -> Tuple[
        List[List[int]], List[List[int]], List[List[int]], Dict[str, List[int]]
    ]:
        """一次性返回 train/val/test 三个划分的序列。

        - use_bpe=True 返回 BPE 压缩序列；否则返回原始序列
        - 不返回 BPE 模型，若需要请使用 `get_bpe_model()`
        """
        if use_bpe:
            all_compressed, split_indices = self.get_compressed_sequences(
                method=method, data_version=data_version, build_if_missing=build_if_missing
            )
            train_sequences = [all_compressed[i] for i in split_indices['train']]
            val_sequences = [all_compressed[i] for i in split_indices['val']]
            test_sequences = [all_compressed[i] for i in split_indices['test']]
            return train_sequences, val_sequences, test_sequences, split_indices
        else:
            all_sequences, split_indices = self.get_sequences(
                method=method, data_version=data_version, build_if_missing=build_if_missing
            )
            train_sequences = [all_sequences[i] for i in split_indices['train']]
            val_sequences = [all_sequences[i] for i in split_indices['val']]
            test_sequences = [all_sequences[i] for i in split_indices['test']]
            return train_sequences, val_sequences, test_sequences, split_indices

    def get_bpe_model(self, method: str, data_version: str = "latest") -> Any:
        """单独获取 BPE 模型：返回已构建好的 BPEEngine（基于保存的 codebook）。"""
        bpe_res = self._load_bpe_result(method, data_version)
        meta = bpe_res.get("bpe_model")
        if not isinstance(meta, dict) or 'merge_rules' not in meta or 'vocab_size' not in meta:
            # 兼容旧格式：直接返回原对象（可能是 StandardBPECompressor）
            return meta
        eng = BPEEngine(
            train_backend='python',  # 此处不用于训练
            encode_backend=str(meta.get('encode_backend', 'cpp')),
            encode_rank_mode=str(meta.get('encode_rank_mode', 'all')),
            encode_rank_k=meta.get('encode_rank_k'),
            encode_rank_min=meta.get('encode_rank_min'),
            encode_rank_max=meta.get('encode_rank_max'),
            encode_rank_dist=meta.get('encode_rank_dist'),
        )
        eng.merge_rules = [tuple(map(int, t)) for t in meta['merge_rules']]
        eng.vocab_size = int(meta['vocab_size'])
        eng.build_encoder()
        return eng

    def get_split_indices(
        self,
        data_version: str = "latest",
        seed: Optional[int] = None,
    ) -> Dict[str, List[int]]:
        """
        获取数据集划分索引。
        
        Args:
            data_version: 数据版本参数（当前忽略，保留接口兼容性）
            seed: 随机种子参数（当前忽略，保留接口兼容性）
            
        Returns:
            包含 'train', 'val', 'test' 索引列表的字典
        """
        # 直接加载原有的三个索引文件
        return self._load_split_indices()

    def get_dataset_loader(self) -> BaseDataLoader:
        """
        获取数据集加载器实例（仅供序列化器等内部组件使用）。
        
        Returns:
            BaseDataLoader 实例
        """
        if self._loader is not None:
            return self._loader
        else:
            self._loader = get_dataloader(self.dataset, self.config)
            return self._loader

    def create_empty_dataset_loader(self) -> BaseDataLoader:
        """
        创建“空”的数据集加载器实例：
        - 实际返回数据层中的 loader 实例；
        - 不触发任何数据加载/预处理动作；
        - 上层可使用该实例的元信息/约定方法。
        """
        return get_dataloader(self.dataset, self.config)

    def get_graphs_by_split(
        self,
        split: str,
        data_version: str = "latest",
        seed: Optional[int] = None,
    ) -> List[Dict[str, Any]]:
        """
        按数据集划分获取图数据。
        
        Args:
            split: 划分名称 ('train', 'val', 'test')
            data_version: 数据版本参数（当前忽略）
            seed: 随机种子参数（当前忽略）
            
        Returns:
            指定划分的图数据列表
        """
        all_graphs = self.get_graphs(data_version)
        split_indices = self._load_split_indices()
        
        if split not in split_indices:
            raise ValueError(f"无效的划分名称: {split}，可用的划分: {list(split_indices.keys())}")
        
        indices = split_indices[split]
        return [all_graphs[i] for i in indices]



    def get_compressed_sequences_by_split(
        self,
        method: str,
        split: str,
        data_version: str = "latest",
        seed: Optional[int] = None,
        *,
        build_if_missing: bool = False,
    ) -> List[List[int]]:
        """
        按数据集划分获取 BPE 压缩序列。
        
        Args:
            method: 序列化方法
            split: 划分名称 ('train', 'val', 'test')
            data_version: 数据版本参数（当前忽略）
            seed: 随机种子参数（当前忽略）
            build_if_missing: 缺失时是否构建
            
        Returns:
            (指定划分的压缩序列列表, BPE 模型)
        """
        # 先验证 split 合法性，避免在无效 split 时不必要地触发缓存加载/构建
        split_indices = self._load_split_indices()
        if split not in split_indices:
            raise ValueError(f"无效的划分名称: {split}，可用的划分: {list(split_indices.keys())}")

        # 获取所有压缩序列
        all_compressed, _ = self.get_compressed_sequences(
            method, data_version, build_if_missing=build_if_missing
        )

        indices = split_indices[split]
        split_compressed = [all_compressed[i] for i in indices]
        return split_compressed

    def get_training_data(
        self,
        method: str,
        *,
        target_property: Optional[str] = None,
        use_bpe: bool = True,
        data_version: str = "latest",
        build_if_missing: bool = False,
    ) -> Tuple[
        List[List[int]], List[List[int]], List[List[int]],
        List[Any], List[Any], List[Any],
        Dict[str, List[int]]
    ]:
        """
        便捷接口：获取 (train/val/test) 的序列与标签，以及 splits。
        
        返回：
        (train_sequences, val_sequences, test_sequences,
         train_labels, val_labels, test_labels,
         split_indices)
        
        说明：
        - 当 target_property 为 None 时，标签列表返回空列表。
        - use_bpe=True 时返回 BPE 压缩序列，否则返回原始序列化结果。
        """
        # 获取 splits
        split_indices = self.get_split_indices(data_version=data_version)

        # 获取序列与属性来源
        if use_bpe:
            # 全量读取一次，以便获取 properties
            all_compressed, _ = self.get_compressed_sequences(
                method=method, data_version=data_version, build_if_missing=build_if_missing
            )
            # 从缓存直接读取属性，避免依赖底层 DataLoader
            bpe_res = self._load_bpe_result(method, data_version)
            properties_all = bpe_res.get("properties", [])

            # 切分序列
            train_sequences = [all_compressed[i] for i in split_indices['train']]
            val_sequences = [all_compressed[i] for i in split_indices['val']]
            test_sequences = [all_compressed[i] for i in split_indices['test']]
        else:
            all_sequences, _ = self.get_sequences(
                method=method, data_version=data_version, build_if_missing=build_if_missing
            )
            ser_res = self._load_serialization_result(method, data_version)
            properties_all = ser_res.get("properties", [])

            train_sequences = [all_sequences[i] for i in split_indices['train']]
            val_sequences = [all_sequences[i] for i in split_indices['val']]
            test_sequences = [all_sequences[i] for i in split_indices['test']]

        # 生成标签
        if target_property is None or not properties_all:
            train_labels: List[Any] = []
            val_labels: List[Any] = []
            test_labels: List[Any] = []
        else:
            # 选择属性键：若只有一个属性键则自动使用之
            selected_key = target_property
            if isinstance(properties_all, list) and properties_all and isinstance(properties_all[0], dict):
                if len(properties_all[0]) == 1:
                    selected_key = list(properties_all[0].keys())[0]
            else:
                raise ValueError("缓存中的 properties 格式不正确")

            def _pick(idx_list: List[int]) -> List[Any]:
                return [properties_all[i][selected_key] for i in idx_list]

            train_labels = _pick(split_indices['train'])
            val_labels = _pick(split_indices['val'])
            test_labels = _pick(split_indices['test'])

        return (
            train_sequences, val_sequences, test_sequences,
            train_labels, val_labels, test_labels,
            split_indices,
        )

    # ----------------------- 下游任务元信息与空DataLoader -----------------------
    def get_downstream_metadata(self) -> Dict[str, Any]:
        """
        返回与下游任务相关的只读元信息：
        - label_keys/label_shapes
        - num_classes（若分类）
        - default_target_property（若回归）
        - dataset_name 等
        说明：不同数据集在对应 loader 内部硬编码其下游任务约定，UDI 汇总暴露。
        """
        loader = self.get_dataset_loader()
        meta: Dict[str, Any] = {
            'dataset': self.dataset,
        }
        # 尝试按约定方法读取（若不存在则忽略）
        for attr in [
            'get_downstream_label_keys',
            'get_downstream_label_shapes',
            'get_num_classes',
            'get_default_target_property',
            'get_dataset_task_type',
        ]:
            if hasattr(loader, attr):
                try:
                    meta[attr.replace('get_', '')] = getattr(loader, attr)()
                except Exception:
                    pass
        return meta

# 空data loader指的就是实际在数据层中的那个data loader。只不过我们不执行他的load data方法。

